{
  "skillId": "github",
  "version": "1.1.0",
  "description": "Git operations; PR bodies must match github/pr_templates.py (universal sections; Related Jira or no-Jira sentinel).",
  "inputs": {
    "type": "object",
    "required": ["operation"],
    "properties": {
      "operation": { "type": "string", "enum": ["create_branch", "open_pr", "request_review"] },
      "base_branch": { "type": "string" },
      "head_branch": { "type": "string" },
      "title": { "type": "string" },
      "body": {
        "type": "string",
        "description": "PR description; must follow github/pr_templates.py (Related Jira keys/URLs or NO_JIRA_STORY_LINE)"
      },
      "reviewers": { "type": "array", "items": { "type": "string" } }
    }
  },
  "outputs": {
    "type": "object",
    "properties": {
      "pr_number": { "type": "integer" },
      "pr_url": { "type": "string" },
      "sha": { "type": "string" }
    }
  }
}
